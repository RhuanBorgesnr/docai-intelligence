# DocAI Intelligence - Configuracao Local
# Copie para .env e ajuste os valores

# Django
SECRET_KEY=sua-chave-secreta-aqui-mude-em-producao
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Banco de Dados (SQLite para desenvolvimento)
# DATABASE_URL=sqlite:///db.sqlite3

# Banco de Dados (PostgreSQL para producao)
# DATABASE_URL=postgresql://user:password@localhost:5432/docai

# Celery (opcional - para processamento assincrono)
# CELERY_BROKER_URL=redis://localhost:6379/0
# CELERY_RESULT_BACKEND=redis://localhost:6379/0
CELERY_TASK_ALWAYS_EAGER=true

# API Keys
GROQ_API_KEY=sua-chave-groq-aqui

# CORS (para producao)
# CORS_ALLOWED_ORIGINS=https://seudominio.com

# Twilio (para notificacoes WhatsApp)
# TWILIO_ACCOUNT_SID=seu-sid
# TWILIO_AUTH_TOKEN=seu-token
# TWILIO_PHONE_NUMBER=+1234567890
